<aside class="sidebar" id="sidebar">
  <div class="brand">
    <div class="logo" title="Creative Reports"><%- h.icon('chart') %></div>
    <div class="brand-text">
      <div class="name">Creative Reports</div>
      <div class="tag">Performance Intelligence</div>
    </div>
  </div>
  <nav class="nav" aria-label="Main navigation">
    <% h.NAV.forEach(function(item) { %>
      <a href="<%= item.href %>" class="nav-link <%= path === item.href ? 'active' : '' %>" title="<%= item.label %>">
        <span class="nav-icon"><%- h.icon(item.icon) %></span>
        <span class="nav-label"><%= item.label %></span>
      </a>
    <% }); %>
  </nav>
  <div class="sidebar-foot">
    <button type="button" class="sidebar-toggle" id="sidebar-toggle" aria-label="Toggle sidebar" title="Toggle sidebar">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M15 18l-6-6 6-6"/></svg>
    </button>
  </div>
</aside>
<div class="sidebar-backdrop" id="sidebar-backdrop" hidden></div>
