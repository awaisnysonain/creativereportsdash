<% if (!snapshot) { %>
  <div class="empty">
    <div class="ico"><%- h.icon('trending') %></div>
    <h3>No analysis available</h3>
    <p>Run a weekly sync or import data to detect winners and decelerators.</p>
  </div>
<% } else { %>
  <div class="card">
    <div class="card-header">
      <div class="card-title">New winners</div>
      <div class="card-desc">Job name = J#### · open-entry title. Prior weekly run-rate &lt; $2K and L7 spend ≥ $10K. Excludes asc+ promo and catalog/Marpipe.</div>
    </div>
    <div class="card-body">
      <div class="table-wrap">
        <table class="data-table sortable">
          <thead><tr>
            <th>Job</th><th data-type="num">L7 spend</th><th data-type="num">Meta ROAS</th><th data-type="num">Attrib. ROAS</th>
          </tr></thead>
          <tbody>
            <% if (!snapshot.winners.length) { %><tr><td colspan="4" class="muted">None flagged this week.</td></tr><% } %>
            <% snapshot.winners.forEach(function(w) { %>
              <tr>
                <td title="<%= h.esc(w.adName) %>"><strong><%= h.esc(w.label) %></strong></td>
                <td class="tabular" data-sort="<%= w.l7Spend %>"><%= h.fmtCurrency(w.l7Spend) %></td>
                <td class="tabular" data-sort="<%= w.metaRoas %>"><%= h.fmtRoas(w.metaRoas) %></td>
                <td class="tabular" data-sort="<%= w.twRoas %>"><%= h.fmtRoas(w.twRoas) %></td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <div class="card">
    <div class="card-header">
      <div class="card-title">Decelerators</div>
      <div class="card-desc">Job name = J#### · open-entry title. Prior wk = L30-minus-L7 spend ÷ 23 × 7. Flags jobs where prior run-rate ≥ $18K and L7 fell below 66% of it.</div>
    </div>
    <div class="card-body">
      <div class="table-wrap">
        <table class="data-table sortable">
          <thead><tr>
            <th>Job</th><th data-type="num">Prior wk</th><th data-type="num">L7 spend</th><th data-type="num">% down</th><th data-type="num">Meta ROAS (L7)</th>
          </tr></thead>
          <tbody>
            <% if (!snapshot.decelerators.length) { %><tr><td colspan="5" class="muted">None flagged this week.</td></tr><% } %>
            <% snapshot.decelerators.forEach(function(d) { %>
              <tr>
                <td title="<%= h.esc(d.adName) %>"><strong><%= h.esc(d.label) %></strong></td>
                <td class="tabular" data-sort="<%= d.priorL7Spend %>"><%= h.fmtCurrency(d.priorL7Spend) %></td>
                <td class="tabular" data-sort="<%= d.currentL7Spend %>"><%= h.fmtCurrency(d.currentL7Spend) %></td>
                <td class="tabular" data-sort="<%= d.dropPct %>"><%= h.fmtPercent(d.dropPct, 0) %></td>
                <td class="tabular" data-sort="<%= d.metaRoas %>"><%= d.metaRoas ? h.fmtRoas(d.metaRoas) : '—' %></td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
<% } %>
