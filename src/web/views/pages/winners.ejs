<% if (!snapshot) { %>
  <div class="empty">
    <div class="ico"><%- h.icon('trending') %></div>
    <h3>No scale signals available</h3>
    <p>Run the weekly report to identify new scale candidates and delivery slowdowns.</p>
  </div>
<% } else { %>
  <div class="card">
    <div class="card-header">
      <div class="card-title">Scale candidates</div>
      <div class="card-desc">Jobs with low prior delivery that reached meaningful current-week spend. Promo, catalog, and Marpipe campaigns are excluded.</div>
    </div>
    <div class="card-body">
      <div class="table-wrap">
        <table class="data-table sortable">
          <thead><tr>
            <th>Job</th><th data-type="num">L7 spend</th><th data-type="num">Meta ROAS</th><th data-type="num">Attributed ROAS</th>
          </tr></thead>
          <tbody>
            <% if (!snapshot.winners.length) { %><tr><td colspan="4" class="muted">No new scale candidates met the threshold this week.</td></tr><% } %>
            <% snapshot.winners.forEach(function(w) { %>
              <tr>
                <td title="<%= h.esc(w.adName) %>"><strong><%= h.esc(w.label) %></strong></td>
                <td class="tabular" data-sort="<%= w.l7Spend %>"><%= h.fmtCurrency(w.l7Spend) %></td>
                <td class="tabular" data-sort="<%= w.metaRoas %>"><%= h.fmtRoas(w.metaRoas) %></td>
                <td class="tabular" data-sort="<%= w.twRoas %>"><%= h.fmtRoas(w.twRoas) %></td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <div class="card">
    <div class="card-header">
      <div class="card-title">Delivery slowdowns</div>
      <div class="card-desc">Jobs whose prior weekly run-rate was meaningful and whose current-week spend has materially dropped.</div>
    </div>
    <div class="card-body">
      <div class="table-wrap">
        <table class="data-table sortable">
          <thead><tr>
            <th>Job</th><th data-type="num">Prior weekly run-rate</th><th data-type="num">L7 spend</th><th data-type="num">Decline</th><th data-type="num">Meta ROAS</th>
          </tr></thead>
          <tbody>
            <% if (!snapshot.decelerators.length) { %><tr><td colspan="5" class="muted">No material delivery slowdowns met the threshold this week.</td></tr><% } %>
            <% snapshot.decelerators.forEach(function(d) { %>
              <tr>
                <td title="<%= h.esc(d.adName) %>"><strong><%= h.esc(d.label) %></strong></td>
                <td class="tabular" data-sort="<%= d.priorL7Spend %>"><%= h.fmtCurrency(d.priorL7Spend) %></td>
                <td class="tabular" data-sort="<%= d.currentL7Spend %>"><%= h.fmtCurrency(d.currentL7Spend) %></td>
                <td class="tabular" data-sort="<%= d.dropPct %>"><%= h.fmtPercent(d.dropPct, 0) %></td>
                <td class="tabular" data-sort="<%= d.metaRoas %>"><%= d.metaRoas ? h.fmtRoas(d.metaRoas) : '—' %></td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
<% } %>
