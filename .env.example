# =============================================================================
# Creative Reports — Environment Variables
# Copy this file to `.env.local` and fill in real values for local development.
#   cp .env.example .env.local
# NEVER commit .env.local — it is git-ignored.
# =============================================================================

# ── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1

# ── Meta (Facebook) Marketing API ────────────────────────────────────────────
META_API_VERSION=v20.0

NOBL_META_AD_ACCOUNT_ID=
NOBL_META_ACCESS_TOKEN=

FLO_META_AD_ACCOUNT_ID=
FLO_META_ACCESS_TOKEN=

# ── Triple Whale (per store/workspace) ───────────────────────────────────────
# NOBL main (US)
NOBL_TW_SHOP_ID=
NOBL_TW_API_KEY=

# FLO main (US)
FLO_TW_SHOP_ID=
FLO_TW_API_KEY=

# NOBL EU workspace
NOBL_EU_TW_SHOP_ID=
NOBL_EU_TW_API_KEY=

# NOBL UK workspace
NOBL_UK_TW_SHOP_ID=
NOBL_UK_TW_API_KEY=

# ── Slack ────────────────────────────────────────────────────────────────────
SLACK_BOT_TOKEN=
SLACK_CHANNEL_ID=C0BFQ93BVT8
# Comma- or space-separated Slack member IDs to DM every posted weekly report.
SLACK_REPORT_USER_IDS=

# ── Reporting / Scheduling ───────────────────────────────────────────────────
REPORT_TIMEZONE=America/New_York
WEEKLY_RUN_DAY=Tuesday
WEEKLY_RUN_HOUR=8

# Public URL for Slack "Open full report" links (required on production server)
# APP_URL=https://reports.yourdomain.com

# Set to "false" to disable the built-in Tuesday cron (default: enabled)
# ENABLE_WEEKLY_SCHEDULER=true

# ── Database (PostgreSQL) ────────────────────────────────────────────────────
# Remote server (direct — requires AWS Security Group to allow your IP on port 5432):
# DATABASE_URL=postgresql://marketing_creative_reports_user:PASSWORD@52.77.228.212:5432/marketing_creative_reports
#
# Local dev via SSH tunnel (recommended):
#   ssh -i "New Server.pem" -L 5432:127.0.0.1:5432 ubuntu@52.77.228.212
#   DATABASE_URL=postgresql://marketing_creative_reports_user:PASSWORD@127.0.0.1:5432/marketing_creative_reports
DATABASE_URL=

# Set to "true" for managed Postgres (required for most remote servers)
DATABASE_SSL=true

# HTTP port (default 3000)
PORT=3000
