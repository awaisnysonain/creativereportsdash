{
  "name": "creative-reports",
  "version": "1.0.0",
  "private": true,
  "description": "Creative Reports — executive creative-performance analytics for paid social (Meta + Triple Whale). Node.js + Express + EJS.",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "tsx src/server.ts",
    "typecheck": "tsc --noEmit",
    "db:migrate": "tsx scripts/migrate.ts",
    "db:seed": "tsx scripts/seed.ts",
    "db:reset": "tsx scripts/migrate.ts --reset",
    "import:csv": "tsx scripts/import-csv.ts",
    "read:xlsx": "tsx scripts/read-xlsx.ts",
    "test:connections": "tsx scripts/test-connections.ts",
    "scheduler": "tsx scripts/scheduler.ts",
    "setup": "tsx scripts/migrate.ts && tsx scripts/seed.ts"
  },
  "dependencies": {
    "@slack/web-api": "^7.8.0",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "ejs": "^3.1.10",
    "express": "^4.21.2",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.3",
    "openai": "^4.77.0",
    "papaparse": "^5.4.1",
    "pg": "^8.13.1",
    "xlsx": "^0.18.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/ejs": "^3.1.5",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.10.5",
    "@types/node-cron": "^3.0.11",
    "@types/papaparse": "^5.3.15",
    "@types/pg": "^8.11.10",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
